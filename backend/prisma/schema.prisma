generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                  Int      @id @default(autoincrement())
  email               String   @unique
  passwordHash        String
  role                String   @default("admin")
  name                String?
  companyName         String?
  logo                String?
  phone               String?
  alternatePhone      String?
  address             String?
  city                String?
  state               String?
  country             String?
  gst                 String?
  rera                String?
  experience          Int?
  projectsDelivered   Int?
  website             String?
  about               String?
  documents           String?
  status              String   @default("active")
  autoWebhookOnSubmit Int      @default(0)
  createdAt           String?
  layouts             Layout[]
  plan                String   @default("FREE")
  planStatus          String   @default("ACTIVE")
  planActivatedAt     DateTime?
  planExpiresAt       DateTime?
  maxLayouts          Int?
  maxViews            Int?
  featuresEnabled     String?
  payments            Payment[]
  @@map("users")
}

model Layout {
  id             Int             @id @default(autoincrement())
  userId         Int
  name           String
  slug           String          @unique
  imagePath      String?
  overlayConfig  String?
  plots          String?
  phaseInfo      String?
  webhookUrl     String?
  layoutKind     String          @default("plot")
  building       String?
  status         String          @default("draft")
  createdAt      String?
  viewCount      Int             @default(0)
  shareToken     String?         @unique
  activityEvents ActivityEvent[]
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  leads          Lead[]

  @@index([slug], map: "idx_layouts_slug")
  @@index([userId], map: "idx_layouts_userId")
  @@map("layouts")
}

model Lead {
  id                 Int     @id @default(autoincrement())
  layoutId           Int
  plotId             String
  trackingId         String? @unique
  customerName       String
  contactNumber      String
  customerEmail      String?
  metadata           String?
  webhookDeliveredAt String?
  webhookLastError   String?
  unitId             String?
  status             String  @default("new")
  statusUpdatedAt    String?
  createdAt          String?
  layout             Layout  @relation(fields: [layoutId], references: [id], onDelete: Cascade)

  @@index([layoutId], map: "idx_leads_layoutId")
  @@map("leads")
}

model ActivityEvent {
  id        Int     @id @default(autoincrement())
  layoutId  Int
  sessionId String
  eventType String
  payload   String?
  userAgent String?
  createdAt String?
  layout    Layout  @relation(fields: [layoutId], references: [id], onDelete: Cascade)

  @@index([sessionId], map: "idx_activity_session")
  @@index([layoutId, createdAt], map: "idx_activity_layout_created")
  @@map("activity_events")
}

model GlobalSetting {
  id        Int     @id @default(autoincrement())
  key       String  @unique
  value     String
  createdAt String?
  @@map("global_settings")
}

model Payment {
  id            Int      @id @default(autoincrement())
  userId        Int
  amount        Float
  currency      String   @default("INR")
  status        String   @default("pending")
  paymentMethod String?
  gatewayId     String?
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId], map: "idx_payments_userId")
  @@map("payments")
}
