generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                  Int      @id @default(autoincrement())
  email               String   @unique
  passwordHash        String
  role                String   @default("admin")
  name                String?
  companyName         String?
  logo                String?
  phone               String?
  alternatePhone      String?
  address             String?
  city                String?
  state               String?
  country             String?
  gst                 String?
  rera                String?
  experience          Int?
  projectsDelivered   Int?
  website             String?
  about               String?
  facebook            String?
  instagram           String?
  linkedin            String?
  youtube             String?
  documents           String?
  status              String   @default("active")
  autoWebhookOnSubmit Int      @default(0)
  createdAt           String?
  layouts             Layout[]

  @@map("users")
}

model Layout {
  id             Int             @id @default(autoincrement())
  userId         Int
  name           String
  slug           String          @unique
  imagePath      String?
  overlayConfig  String?
  plots          String?
  phaseInfo      String?
  webhookUrl     String?
  layoutKind     String          @default("plot")
  building       String?
  status         String          @default("draft")
  createdAt      String?
  activityEvents ActivityEvent[]
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  leads          Lead[]

  @@index([slug], map: "idx_layouts_slug")
  @@index([userId], map: "idx_layouts_userId")
  @@map("layouts")
}

model Lead {
  id                 Int     @id @default(autoincrement())
  layoutId           Int
  plotId             String
  trackingId         String? @unique
  customerName       String
  contactNumber      String
  customerEmail      String?
  metadata           String?
  webhookDeliveredAt String?
  webhookLastError   String?
  unitId             String?
  status             String  @default("new")
  statusUpdatedAt    String?
  createdAt          String?
  layout             Layout  @relation(fields: [layoutId], references: [id], onDelete: Cascade)

  @@index([layoutId], map: "idx_leads_layoutId")
  @@map("leads")
}

model ActivityEvent {
  id        Int     @id @default(autoincrement())
  layoutId  Int
  sessionId String
  eventType String
  payload   String?
  userAgent String?
  createdAt String?
  layout    Layout  @relation(fields: [layoutId], references: [id], onDelete: Cascade)

  @@index([sessionId], map: "idx_activity_session")
  @@index([layoutId, createdAt], map: "idx_activity_layout_created")
  @@map("activity_events")
}
