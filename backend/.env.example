PORT=3002
JWT_SECRET=your-secret-key-change-in-production
DATABASE_PATH=./data/plotapp.db
# CORS: set to the URL you open in the browser (default dev is one server on PORT).
FRONTEND_URL=http://localhost:3002
NODE_ENV=development

# `npm run dev` runs Express + Vite on PORT (default 3002). Leave VITE_API_URL unset
# so the browser calls same-origin /api and /uploads.
# Split setup: `npm run dev:client` (Vite 5173) + `npm run dev:server` (API 3002) — then
# leave VITE_API_URL unset; Vite proxies /api to 3002.
# Never set VITE_API_URL to the Vite port — breaks proxy / causes /api 404.
# Optional direct API URL: VITE_API_URL=http://localhost:3002

# First-run bootstrap: creates admin user if none exists (optional)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Set to true only in dev if you need open self-registration
ALLOW_PUBLIC_SIGNUP=false
